# ============================================================
# Py2APK – Environment variables
# Copy this file to .env and adjust the values.
# DO NOT commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
DEBUG=false

# IMPORTANT: Change this to a long random string in production!
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production-please

# ── Authentication (set to true to enable login) ─────────────────────────
ENABLE_AUTH=false
# SESSION_EXPIRY=86400   # seconds (default 24h)

# ── Docker build settings ─────────────────────────────────────────────────
DOCKER_BUILDER_IMAGE=py2apk-builder:latest
DOCKER_MEMORY_LIMIT=4g
DOCKER_CPU_LIMIT=2
# DOCKER_NETWORK=none   # no network access inside build containers
BUILD_TIMEOUT=3600      # seconds (default 1 hour)
MAX_CONCURRENT_BUILDS=2

# ── Upload limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=104857600   # bytes (default 100 MB)

# ── Storage & cleanup ─────────────────────────────────────────────────────
DATA_DIR=data
BUILD_EXPIRY_DAYS=7         # builds older than this are auto-deleted
CLEANUP_INTERVAL=3600       # how often to run cleanup (seconds)

# ── Email notifications (optional) ───────────────────────────────────────
# Leave SMTP_HOST empty to disable email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@py2apk.local

# ── Pagination ────────────────────────────────────────────────────────────
PAGE_SIZE=20

# ── Nginx (docker-compose with-nginx profile) ─────────────────────────────
HOST_PORT=8080
